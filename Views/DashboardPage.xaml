<Page x:Class="OptiCleanPro.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="18,15">

            <!-- ══ TOP SERVICE BUTTONS ══ -->
            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" BorderBrush="#0078D4" BorderThickness="2"
                        CornerRadius="8" Padding="12,14" Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{x:Null}"/>
                    </Border.InputBindings>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="30" Foreground="#0078D4"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Quick" FontSize="13" Foreground="#0078D4" FontWeight="SemiBold"/>
                            <TextBlock Text="Chat"  FontSize="13" Foreground="#0078D4" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" BorderBrush="#0078D4" BorderThickness="2"
                        CornerRadius="8" Padding="12,14" Cursor="Hand">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="30" Foreground="#4CAF50"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Expert" FontSize="13" Foreground="#0078D4" FontWeight="SemiBold"/>
                            <TextBlock Text="Support" FontSize="13" Foreground="#0078D4" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ HEALTH STATUS ══ -->
            <StackPanel HorizontalAlignment="Center" Margin="0,8,0,18">
                <Grid Width="68" Height="68" HorizontalAlignment="Center">
                    <Ellipse Fill="#4CAF50"/>
                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets"
                               FontSize="30" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
                <TextBlock Text="Your computer is healthy"
                           FontSize="15" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,12,0,0" Foreground="#222"/>
            </StackPanel>

            <!-- ══ METRICS ══ -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Processor -->
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Processor" FontSize="11" Foreground="#888"/>
                        <TextBlock Grid.Column="1" x:Name="CpuLabel" Text="10%" FontSize="11" Foreground="#888"/>
                    </Grid>
                    <ProgressBar x:Name="CpuBar" Value="10" Maximum="100"
                                 Height="5" Margin="0,3,0,0"
                                 Background="#E0E0E0" Foreground="#4CAF50"/>
                </StackPanel>

                <!-- Storage -->
                <StackPanel Grid.Column="1" Margin="4,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Storage" FontSize="11" Foreground="#888"/>
                        <TextBlock Grid.Column="1" x:Name="StorageLabel" Text="5%" FontSize="11" Foreground="#888"/>
                    </Grid>
                    <ProgressBar x:Name="StorageBar" Value="5" Maximum="100"
                                 Height="5" Margin="0,3,0,0"
                                 Background="#E0E0E0" Foreground="#4CAF50"/>
                </StackPanel>

                <!-- Memory -->
                <StackPanel Grid.Column="2" Margin="8,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Memory" FontSize="11" Foreground="#888"/>
                        <TextBlock Grid.Column="1" x:Name="MemLabel" Text="57%" FontSize="11" Foreground="#888"/>
                    </Grid>
                    <ProgressBar x:Name="MemBar" Value="57" Maximum="100"
                                 Height="5" Margin="0,3,0,0"
                                 Background="#E0E0E0" Foreground="#E69500"/>
                </StackPanel>
            </Grid>

            <!-- ══ FEATURE GRID ══ -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Performance -->
                <Button Grid.Row="0" Grid.Column="0" Click="Nav_Performance"
                        Style="{StaticResource FeatureTile}">
                    <StackPanel>
                        <TextBlock Text="&#xE9D9;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="32" HorizontalAlignment="Center">
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#E53935" Offset="0"/>
                                    <GradientStop Color="#FB8C00" Offset="0.4"/>
                                    <GradientStop Color="#4CAF50" Offset="1"/>
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                        </TextBlock>
                        <TextBlock Text="Performance" FontSize="12" Foreground="#444"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Privacy -->
                <Button Grid.Row="0" Grid.Column="1" Style="{StaticResource FeatureTile}">
                    <StackPanel>
                        <TextBlock Text="&#xEA18;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="32" Foreground="#0078D4" HorizontalAlignment="Center"/>
                        <TextBlock Text="Privacy" FontSize="12" Foreground="#444"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Security -->
                <Button Grid.Row="0" Grid.Column="2" Click="Nav_Security"
                        Style="{StaticResource FeatureTile}">
                    <StackPanel>
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="32" Foreground="#0078D4" HorizontalAlignment="Center"/>
                        <TextBlock Text="Security" FontSize="12" Foreground="#444"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Clean Up -->
                <Button Grid.Row="1" Grid.Column="0" Style="{StaticResource FeatureTile}">
                    <StackPanel>
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="32" Foreground="#555" HorizontalAlignment="Center"/>
                        <TextBlock Text="Clean Up" FontSize="12" Foreground="#444"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Network -->
                <Button Grid.Row="1" Grid.Column="1" Style="{StaticResource FeatureTile}">
                    <StackPanel>
                        <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="32" Foreground="#0078D4" HorizontalAlignment="Center"/>
                        <TextBlock Text="Network" FontSize="12" Foreground="#444"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

                <!-- Settings -->
                <Button Grid.Row="1" Grid.Column="2" Style="{StaticResource FeatureTile}">
                    <StackPanel>
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                   FontSize="32" Foreground="#0078D4" HorizontalAlignment="Center"/>
                        <TextBlock Text="Settings" FontSize="12" Foreground="#444"
                                   HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Button>

            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>