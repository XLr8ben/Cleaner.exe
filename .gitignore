## Visual Studio / .NET .gitignore

# =============================================================================
# Build outputs
# =============================================================================
bin/
obj/

# =============================================================================
# Publish output
# =============================================================================
publish/

# =============================================================================
# Installer output (generated by Inno Setup)
# =============================================================================
installer_output/

# =============================================================================
# Visual Studio files
# =============================================================================
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Visual Studio 2015/2017 cache / options directory
.vs/

# MSTest test results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# =============================================================================
# NuGet
# =============================================================================
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets
project.lock.json
project.fragment.lock.json
artifacts/

# =============================================================================
# Roslyn / Analyzers
# =============================================================================
*.rsuser

# =============================================================================
# JetBrains Rider
# =============================================================================
.idea/
*.sln.iml

# =============================================================================
# Windows OS
# =============================================================================
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# =============================================================================
# Logs & crash dumps
# =============================================================================
*.log
*.stackdump
crashdump*.dmp

# =============================================================================
# Temporary files
# =============================================================================
*.tmp
*.temp
*~
