<Window x:Class="OptiCleanPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OptiClean Pro" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

    <!-- ✅ Styles defined HERE so they are always found -->
    <Window.Resources>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background"                  Value="Transparent"/>
            <Setter Property="Foreground"                  Value="#CCCCCC"/>
            <Setter Property="FontSize"                    Value="14"/>
            <Setter Property="FontWeight"                  Value="SemiBold"/>
            <Setter Property="Height"                      Value="45"/>
            <Setter Property="Margin"                      Value="10,4"/>
            <Setter Property="Cursor"                      Value="Hand"/>
            <Setter Property="BorderThickness"             Value="0"/>
            <Setter Property="HorizontalContentAlignment"  Value="Left"/>
            <Setter Property="Padding"                     Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#2A2A3E"/>
                                <Setter Property="Foreground"                     Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#5865F2"/>
                                <Setter Property="Foreground"                     Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>
         
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="210"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════════════ SIDEBAR ══════════════ -->
        <Border Grid.Column="0" Background="#181825">
            <StackPanel>

                <!-- Logo / App Name -->
                <StackPanel Orientation="Horizontal" Margin="20,30,0,30">
                    <TextBlock Text="⚡" FontSize="22" Foreground="#5865F2" VerticalAlignment="Center"/>
                    <TextBlock Text=" OptiClean" Foreground="White"
                               FontSize="19" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Nav Buttons -->
                <Button Content=" 🏠  Dashboard"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Dashboard"/>
                        
                <Button Content="🗂️  Storage"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Storage"/>

                <Button Content="🛡️  Security"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Security"/>

                <Button Content="⚡  Performance"
                        Style="{StaticResource NavButton}"
                        Click="Nav_Performance"/>

                <!-- Version at bottom -->
                <TextBlock x:Name="VersionLabel" Text="v1.0.0" Foreground="#555"
                           FontSize="11" Margin="20,0"
                           VerticalAlignment="Bottom"/>
            </StackPanel>
        </Border>

        <!-- ══════════════ CONTENT AREA ══════════════ -->
        <Border Grid.Column="1" Background="#1E1E2E">
            <Frame x:Name="MainFrame"
                   NavigationUIVisibility="Hidden"/>
        </Border>

    </Grid>
</Window>